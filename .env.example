APP_ENV=production
APP_BASE_URL=http://localhost:3000

# Local Supabase/Postgres. Example:
# postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_DB_URL_LOCAL=

# Production Supabase direct connection string.
SUPABASE_DB_URL_PRODUCTION=

# Fallback used when the env-specific value is empty.
DATABASE_URL=

# Supabase Auth for Google login.
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# LLM via Replicate
REPLICATE_API_TOKEN=
REPLICATE_CHAT_MODEL=openai/gpt-4o-mini
REPLICATE_EMBEDDING_MODEL=beautyyuyanli/multilingual-e5-small
REPLICATE_MAX_COMPLETION_TOKENS=4096

# RAG behavior
NUTRI_DOC_MATCH_COUNT=6
NUTRI_DOC_MATCH_THRESHOLD=0.68
